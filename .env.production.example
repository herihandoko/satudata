# Production .env template untuk VM
# Copy ke `.env` di server PRODUCTION (ssh ssh-banten-prod → 10.249.100.25)
# Development/staging: VM ssh-banten-dev (10.255.100.246) — pakai .env terpisah di sana
# Copy ke `.env` di VM, lalu isi nilai yang ditandai CHANGE_ME
#
# Aturan keamanan:
# - File ini boleh ke-commit ke git (template, no real secrets)
# - File `.env` (yang asli, dengan secret) JANGAN ke-commit (sudah di-gitignore)

# === Data location ===
# Folder di host VM untuk menyimpan data persistent (postgres, solr, ckan_storage, redis)
# Buat manual: mkdir -p /var/lib/satudata-data/{postgres,solr,ckan_storage,redis}
DATA_DIR=/var/lib/satudata-data

# === Host Ports ===
# CKAN diexpose hanya di 127.0.0.1 (loopback). Host nginx yang serve HTTPS.
CKAN_PORT_HOST=8080

# === Database — GENERATE STRONG PASSWORDS! ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password
POSTGRES_DB=postgres
POSTGRES_HOST=db
CKAN_DB_USER=ckandbuser
CKAN_DB_PASSWORD=CHANGE_ME_strong_ckan_db_password
CKAN_DB=ckandb
DATASTORE_READONLY_USER=datastore_ro
DATASTORE_READONLY_PASSWORD=CHANGE_ME_strong_datastore_password
DATASTORE_DB=datastore
CKAN_SQLALCHEMY_URL=postgresql://ckandbuser:CHANGE_ME_strong_ckan_db_password@db/ckandb
CKAN_DATASTORE_WRITE_URL=postgresql://ckandbuser:CHANGE_ME_strong_ckan_db_password@db/datastore
CKAN_DATASTORE_READ_URL=postgresql://datastore_ro:CHANGE_ME_strong_datastore_password@db/datastore

# === Test database (tidak dipakai di prod, isi placeholder) ===
TEST_CKAN_SQLALCHEMY_URL=postgres://ckan:ckan@db/ckan_test
TEST_CKAN_DATASTORE_WRITE_URL=postgresql://ckan:ckan@db/datastore_test
TEST_CKAN_DATASTORE_READ_URL=postgresql://datastore_ro:datastore@db/datastore_test

# === CKAN core ===
CKAN_VERSION=2.11.0
CKAN_SITE_ID=default
CKAN_SITE_URL=https://data.bantenprov.go.id
CKAN___CKAN__SITE_TITLE=SATU DATA BANTEN
CKAN___CKAN__SITE_DESCRIPTION=Portal Resmi Data Terbuka Pemerintah Provinsi Banten
CKAN___CKAN__SITE_LOGO=/banten/images/logo.png

# === Secrets — GENERATE NEW! ===
# Generate dengan: openssl rand -base64 48
CKAN___BEAKER__SESSION__SECRET=CHANGE_ME_random_64_chars
CKAN___API_TOKEN__JWT__ENCODE__SECRET=string:CHANGE_ME_random_64_chars
CKAN___API_TOKEN__JWT__DECODE__SECRET=string:CHANGE_ME_random_64_chars

# === Sysadmin (auto-created on first boot) ===
CKAN_SYSADMIN_NAME=admin
CKAN_SYSADMIN_PASSWORD=CHANGE_ME_strong_admin_password
CKAN_SYSADMIN_EMAIL=admin@bantendev.id

# === Storage ===
CKAN_STORAGE_PATH=/var/lib/ckan

# === Email/SMTP (configure dengan SMTP yang valid) ===
CKAN_SMTP_SERVER=smtp.example.com:587
CKAN_SMTP_STARTTLS=True
CKAN_SMTP_USER=user@example.com
CKAN_SMTP_PASSWORD=CHANGE_ME_smtp_password
CKAN_SMTP_MAIL_FROM=noreply@bantendev.id

CKAN_MAX_UPLOAD_SIZE_MB=100
TZ=Asia/Jakarta

# === Metabase Metrix ===
# Opsi A (prioritas): embed langsung ke Metabase — hanya untuk user di jaringan/VPN
# yang bisa akses IP internal. HTTPS portal + HTTP iframe = mixed content di browser publik.
# METABASE_DIRECT_DASHBOARD_URL=http://10.255.100.65:3000/public/dashboard/074806cf-11d0-481b-8714-c78d9856621d
#
# Opsi B: signed embed via nginx proxy /metrix-dashboard (rekomendasi publik internet)
# Secret dari Metabase Admin → Settings → Embedding (JANGAN commit nilai asli)
METABASE_EMBED_SECRET=CHANGE_ME_metabase_embedding_secret
METABASE_DASHBOARD_ID=23
# Path same-origin di browser (bukan http://10.255.100.65:3000)
METABASE_EMBED_SITE_URL=/metrix-dashboard
METABASE_EMBED_EXPIRY_MINUTES=10
METABASE_EMBED_FRAGMENT=bordered=true&titled=true
# Fallback jika secret kosong (public dashboard UUID):
# METABASE_PUBLIC_DASHBOARD_PATH=/metrix-dashboard/public/dashboard/074806cf-...

# === Solr ===
SOLR_IMAGE_VERSION=2.11-solr9
CKAN_SOLR_URL=http://solr:8983/solr/ckan

# === Redis ===
REDIS_VERSION=6
CKAN_REDIS_URL=redis://redis:6379/1

# === Datapusher ===
DATAPUSHER_VERSION=0.0.21
CKAN_DATAPUSHER_URL=http://datapusher:8800
# CALLBACK harus URL yang container datapusher bisa hit ke ckan
CKAN__DATAPUSHER__CALLBACK_URL_BASE=http://ckan:5000

# === Plugins (urutan PENTING: envvars terakhir!) ===
CKAN__PLUGINS="image_view text_view datatables_view datastore datapusher banten_theme envvars"
CKAN__HARVEST__MQ__TYPE=redis
CKAN__HARVEST__MQ__HOSTNAME=redis
CKAN__HARVEST__MQ__PORT=6379
CKAN__HARVEST__MQ__REDIS_DB=1
