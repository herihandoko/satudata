# Example nginx site config untuk satudata.bantendev.id
# Copy/adapt ke /etc/nginx/sites-available/satudata, lalu symlink ke sites-enabled
#
#   sudo cp deploy/nginx-satudata.conf.example /etc/nginx/sites-available/satudata
#   sudo ln -sf /etc/nginx/sites-available/satudata /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx

# HTTP -> HTTPS redirect
server {
    listen 80;
    server_name satudata.bantendev.id;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name satudata.bantendev.id;

    # SSL — sesuaikan dengan lokasi cert yang ada di VM
    # ssl_certificate     /etc/ssl/certs/satudata.bantendev.id.crt;
    # ssl_certificate_key /etc/ssl/private/satudata.bantendev.id.key;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    # Logging
    access_log /var/log/nginx/satudata.access.log;
    error_log  /var/log/nginx/satudata.error.log;

    # Upload size — match CKAN_MAX_UPLOAD_SIZE_MB
    client_max_body_size 100M;

    # Gzip
    gzip on;
    gzip_types text/plain text/css text/xml application/json application/javascript application/xml+rss;
    gzip_min_length 1024;

    # Proxy to docker CKAN (loopback)
    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_read_timeout 300s;
        proxy_connect_timeout 75s;

        # Buffering off untuk streaming/large downloads
        proxy_buffering off;
        proxy_request_buffering off;
    }

    # Static optimization (cache CKAN /webassets/)
    location /webassets/ {
        proxy_pass http://127.0.0.1:8080;
        proxy_cache_valid 200 7d;
        expires 7d;
        add_header Cache-Control "public";
    }
}
